{
  "name": "live-copilot",
  "version": "0.1.0",
  "description": "Live Copilot - asistente de escritorio privado con BYOK",
  "main": "./out/main/index.js",
  "author": "Live Copilot",
  "private": true,
  "scripts": {
    "dev": "node scripts/electron-vite.cjs dev",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "typecheck": "tsc -b --noEmit",
    "build": "electron-vite build && node scripts/protect-build.cjs",
    "start": "node scripts/electron-vite.cjs preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "release:portable": "npm run dist:portable && node scripts/make-release.cjs",
    "dist:portable:signed": "npm run build && electron-builder --win portable --config electron-builder.signed.config.cjs",
    "release:portable:signed": "npm run dist:portable:signed && node scripts/make-release.cjs",
    "build:plain": "electron-vite build",
    "protect": "node scripts/protect-build.cjs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.4",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "javascript-obfuscator": "^5.4.2",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.livecopilot.app",
    "productName": "Live Copilot",
    "icon": "icon.ico",
    "files": [
      "out/**/*",
      "resources/**/*",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!node_modules/**/src/**"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "asar": true,
    "compression": "maximum"
  },
  "license": "SEE LICENSE IN LICENSE"
}
